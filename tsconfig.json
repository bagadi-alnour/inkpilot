{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@writeflow/types": ["./src/types"],
      "@writeflow/core": ["./src/core"],
      "@writeflow/core/*": ["./src/core/*"],
      "@writeflow/ai": ["./src/ai"],
      "@writeflow/ai/*": ["./src/ai/*"],
      "@writeflow/seo": ["./src/seo"],
      "@writeflow/seo/*": ["./src/seo/*"],
      "@writeflow/storage": ["./src/storage"],
      "@writeflow/storage/*": ["./src/storage/*"],
      "@writeflow/image": ["./src/image"],
      "@writeflow/image/*": ["./src/image/*"],
      "@writeflow/theme": ["./src/theme"],
      "@writeflow/theme/*": ["./src/theme/*"],
      "@writeflow/i18n": ["./src/i18n"],
      "@writeflow/i18n/*": ["./src/i18n/*"],
      "@writeflow/react": ["./src/react"],
      "@writeflow/react/*": ["./src/react/*"],
      "@writeflow/utils": ["./src/utils"],
      "@writeflow/utils/*": ["./src/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "tests", "examples"]
}
